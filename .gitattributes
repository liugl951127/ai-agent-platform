# Git attributes - 防止 merge 冲突 & 控制 diff 行为
# https://git-scm.com/docs/gitattributes

# 文本文件统一 LF
* text=auto eol=lf

# Java
*.java text eol=lf diff=java
*.jar binary

# 前端
*.vue text eol=lf
*.js  text eol=lf
*.css text eol=lf
*.html text eol=lf

# 文档 / 配置
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.sql text eol=lf
*.properties text eol=lf

# 二进制
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz  binary
*.tar binary
